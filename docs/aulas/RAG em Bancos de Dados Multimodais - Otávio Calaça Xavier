stgreSQL (Supabase) bem-sucedida!\n"]}],"source":["# Criando a string de conexão para o PostgreSQL\n","import psycopg2\n","\n","try:\n","    url = f\"postgresql://{SUPABASE_USER}:{SUPABASE_PASSWORD}@aws-1-us-east-1.pooler.supabase.com:6543/{SUPABASE_DATABASE}\"\n","    conn_pg = psycopg2.connect(url)\n","    print(\"Conexão com o PostgreSQL (Supabase) bem-sucedida!\")\n","    conn_pg.close()\n","except Exception as e:\n","    print(f\"Falha na conexão com o PostgreSQL: {e}\")"]},{"cell_type":"markdown","metadata":{"id":"HB9--zhEZdvp"},"source":["#### Conexão com OpenAI:"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":2964,"status":"ok","timestamp":1762935819279,"user":{"displayName":"Otávio Calaça Xavier","userId":"01740336921478534983"},"user_tz":180},"id":"cd3D9dLQZee7","outputId":"faf4b856-1bdf-46b0-e2a7-7dd3d12461b9"},"outputs":[{"name":"stdout","output_type":"stream","text":["Token da API da OpenAI é válido e a conexão foi bem-sucedida!\n"]}],"source":["# Validando o token da API da OpenAI\n","from openai import OpenAI\n","\n","try:\n","    client = OpenAI()\n","    # Fazendo uma chamada leve para listar os modelos e validar a chave\n","    client.models.list()\n","    print(\"Token da API da OpenAI é válido e a conexão foi bem-sucedida!\")\n","except Exception as e:\n","    print(f\"Falha na validação do token da OpenAI: {e}. Por favor, verifique sua chave 'OPENAI_API_KEY'.\")"]},{"cell_type":"markdown","metadata":{"id":"Ft4QEfHTZDtO"},"source":["#### Conexão com Neo4j AuraDB:"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":402,"status":"ok","timestamp":1762935897309,"user":{"displayName":"Otávio Calaça Xavier","userId":"01740336921478534983"},"user_tz":180},"id":"4P3wP0m8Y_TE","outputId":"66661475-9a1b-46af-94f4-38ce4bf05945"},"outputs":[{"name":"stdout","output_type":"stream","text":["Conexão 