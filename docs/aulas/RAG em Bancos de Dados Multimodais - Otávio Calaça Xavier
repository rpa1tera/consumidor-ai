0'], ['It Came from Outer Space', 'A spaceship from another world crashes in the Arizona desert, and only an amateur stargazer and a schoolteacher suspect alien influence when the local townsfolk begin to act strange.', 1953.0, 6.6, '2661']]\n","Dados de filmes inseridos com sucesso no Supabase!\n","Conexões com bancos de dados fechadas.\n"]}],"source":["import psycopg2\n","from neo4j import GraphDatabase\n","import pandas as pd\n","from tqdm.auto import tqdm # Import tqdm\n","from psycopg2.extras import execute_values # Import execute_values\n","\n","# Conexão com Neo4j\n","driver_neo4j = GraphDatabase.driver(NEO4J_URI, auth=(NEO4J_USERNAME, NEO4J_PASSWORD))\n","\n","# Conexão com PostgreSQL (Supabase)\n","supabase_url = f\"postgresql://{SUPABASE_USER}:{SUPABASE_PASSWORD}@aws-1-us-east-1.pooler.supabase.com:6543/{SUPABASE_DATABASE}\"\n","conn_pg = psycopg2.connect(supabase_url)\n","cur_pg = conn_pg.cursor()\n","\n","# 1. Extrair dados de filmes do Neo4j\n","print(\"Extraindo dados de filmes do Neo4j...\")\n","def get_movies(tx):\n","    result = tx.run(\"MATCH (m:Movie) RETURN m.title, m.plot, m.year, m.imdbRating, m.movieId\")\n","    return [record for record in result]\n","\n","with driver_neo4j.session() as session:\n","    movies_data = session.execute_read(get_movies)\n","\n","# Fechar conexão Neo4j\n","driver_neo4j.close()\n","\n","# Converter para DataFrame para facilitar o processamento\n","movies_df = pd.DataFrame(movies_data)\n","\n","if not movies_df.empty:\n","    # 2. Criar tabela no Supabase (se não existir)\n","    print(\"Criando tabela 'movies' no Supabase...\")\n","    create_table_query = \"\"\"\n","    CREATE TABLE IF NOT EXISTS movies (\n","        id SERIAL PRIMARY KEY,\n","        title VARCHAR(255) NOT NULL,\n","        plot TEXT,\n","        year INTEGER,\n","        imdb_rating REAL,\n","        movie_id INTEGER\n","    );\n","    \"\"\"\n","    cur_pg.execute(create_table_query)\n","    conn_pg.commit()\n","    print(\"Tabela 'movies' verificada/criada.\")\n","\n","    # 3. Popular a tabela no Supabase com inserção em batch usando execute_values\n","    print(f\"Inserindo {len(movies_df)} filmes na tabela 'movies'...\")\n","    insert_query = \"\"\"\n","    INSERT INTO movies (title, plot, year, imdb_rating, movie_id) VALUES %s;\n","    \"\"\"\n","    batch_size = 100 # Define o tamanho do batch, adjust as needed\n","    data_to_insert = movies_df[movies_df[1].notnull()].values.tolist()\n","\n","    try:\n","      for i in tqdm(range(0, len(data_to_insert), batch_size), desc=\"Inserindo filmes\"):\n","          batch = data_to_insert[i:i + batch_size]\n","          execute_values(cur_pg, insert_query, batch)\n","          conn_pg.commit()\n","    except:\n","      print(batch)\n","\n","    print(\"Dados de filmes inseridos com sucesso no Supabase!\")\n","else:\n","    print(\"Nenhum filme encontrado no Neo4j para inserir no Supabase.\")\n","\n","\n","# Fechar conexão PostgreSQL\n","cur_pg.close()\n","conn_pg.close()\n","print(\"Conexões com bancos de dados fechadas.\")"]},{"cell_type":"markdown","metadata":{"id":"OPSyPDkaAjbP"},"source":["## Hands-on: Busca Full-Text com PostgreSQL\n","\n","### Otimizando a Tabela para Busca Textual\n","\n","Para que a busca textual seja eficiente, não podemos simplesmente usar um `LIKE '%termo%'`. Vamos usar as ferramentas corretas do PostgreSQL: `tsvector` e um índice GIN.\n","\n","1. **Adicionar uma coluna `tsvector`**: Esta coluna armazenará os títulos em um formato otimizado para busca, com palavras normalizadas (stemming) e sem stop words.\n","\n","2. **Criar um índice GIN**: Um índice GIN (Generalized Inverted Index) é a estrutura de dados ideal para acelerar a busca em colunas tsvector."]},{"cell_type":"code","execution_count":null,"metadata":{"id":"VC_9bx05FJJO"},"outputs":[],"source":["from sqlalchemy import create_engine, text\n","engine = create_engine(supabase_url)"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":4119,"status":"ok","timestamp":1759294193591,"user":{"displayName":"Otávio Calaça Xavier","userId":"01740336921478534983"},"user_tz":180},"id":"WRjTHdKeFXUZ","outputId":"678c5a8c-90eb-4459-b91e-eece97222964"},"outputs":[{"name":"stdout","output_type":"stream","text":["Coluna 'fts' e índice GIN criados com sucesso!\n"]}],"source":["# Conectando para executar comandos SQL de otimização\n","try:\n","    with engine.connect() as connection:\n","        # 1. Adicionar a coluna tsvector\n","        connection.execute(text(\"ALTER TABLE movies ADD COLUMN fts tsvector;\"))\n","\n","        # 2. Popular a nova coluna com os dados dos títulos em português\n","        connection.execute(text(\"UPDATE movies SET fts = to_tsvector('english', title || ' ' || plot);\"))\n","\n","        # 3. Criar o índice GIN na coluna tsvector\n","        connection.execute(text(\"CREATE INDEX fts_idx ON movies USING GIN(fts);\"))\n","\n","        # Commit das transações\n","        connection.commit()\n","\n","    print(\"Coluna 'fts' e índice GIN criados com sucesso!\")\n","except Exception as e:\n","    print(f\"Erro ao otimizar a tabela: {e}\")"]},{"cell_type":"markdown","metadata":{"id":"zQ6LNNSJHgq-"},"source":["### Executando Buscas Full-Text\n","Agora que tudo está otimizado, podemos realizar buscas. Usaremos a função `to_tsquery` para converter a string de busca do usuário e o operador `@@` para comparar com nosso índice. Também usaremos a função `ts_rank` para obter um score de relevância."]},{"cell_type":"code","execution_count":null,"metadata":{"id":"V8SRY5HiG3Vb"},"outputs":[],"source":["def search_full_text(query, phrase=False):\n","    if phrase:\n","      query = query.replace(\" \", \" | \")\n","    \"\"\"Função para buscar filmes usando Full-Text Search e retornar um DataFrame.\"\"\"\n","    sql_query = text(\"\"\"\n","        SELECT movie_id, title, plot, year, ts_rank(fts, to_tsquery(:query)) as relevance\n","        FROM movies\n","        WHERE fts @@ to_tsquery(:query)\n","        ORDER BY relevance DESC\n","        LIMIT 10;\n","    \"\"\")\n","    with engine.connect() as connection:\n","        result = connection.execute(sql_query, {'query': query})\n","        return pd.DataFrame(result.fetchall(), columns=result.keys())"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":703},"executionInfo":{"elapsed":1521,"status":"ok","timestamp":1759310571250,"user":{"displayName":"Otávio Calaça Xavier","userId":"01740336921478534983"},"user_tz":180},"id":"JdCtq7VOG6J_","outputId":"93716a0e-98e8-46ed-888a-687ae0098a9c"},"outputs":[{"name":"stdout","output_type":"stream","text":["--- Buscando por 'love' ---\n"]},{"data":{"application/vnd.google.colaboratory.intrinsic+json":{"summary":"{\n  \"name\": \"display(search_full_text('godfather | corleone'))\",\n  \"rows\": 10,\n  \"fields\": [\n    {\n      \"column\": \"movie_id\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 25645,\n        \"min\": 178,\n        \"max\": 71823,\n        \"num_unique_values\": 10,\n        \"samples\": [\n          26435,\n          1056,\n          71823\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"title\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 10,\n        \"samples\": [\n          \"Starting Over\",\n          \"Jude\",\n          \"New York, I Love You\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"plot\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 10,\n        \"samples\": [\n          \"A divorced man falls in love, but somehow he can't get over his ex-wife. This affects his love life in comic ways. Based on Dan Wakefield's novel.\",\n          \"A stonemason steadfastly pursues