# ========================
# Python environments
# ========================
.env
.venv
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ========================
# Byte-compiled / optimized
# ========================
__pycache__/
*.py[cod]
*$py.class

# ========================
# Packages & Dependencies
# ========================
# uv
# uv.lock is usually kept in version control to lock dependencies!
# we do NOT ignore uv.lock or pyproject.toml

*.egg
*.egg-info/
.eggs/
build/
develop-eggs/
dist/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
.installed.cfg

# ========================
# Project Data & Models
# ========================
# Ignore raw data, databases, and vector stores
data/raw/*
!data/raw/.gitkeep
data/faiss_index/*
!data/faiss_index/.gitkeep

# Other typical data/model folders
*.sqlite3
*.db
*.faiss
*.pkl
*.parquet
*.csv

# ========================
# Jupyter Notebooks
# ========================
.ipynb_checkpoints
*.ipynb_checkpoints/

# ========================
# Tooling & Testing
# ========================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ========================
# Custom Logs
# ========================
*.log
logs/
debug/

# ========================
# IDEs & OS Files
# ========================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
